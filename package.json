{
  "name": "xtech-supabase",
  "displayName": "XTECH Supabase",
  "description": "Manage local and linked Supabase environments from VS Code",
  "version": "0.0.3",
  "publisher": "XanecTechnologies",
  "engines": {
    "vscode": "^1.85.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/CharlesDeJager/xtech-supabase.git"
  },
  "license": "MIT",
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "workspaceContains:**/supabase/config.toml"
  ],
  "icon": "assets/xanectech-logo.png",
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "supabase",
          "title": "Supabase",
          "icon": "assets/xanectech-logo.svg"
        }
      ]
    },
    "views": {
      "supabase": [
        {
          "id": "xtech-supabase.supabaseExplorer",
          "name": "Supabase Explorer"
        }
      ]
    },
    "commands": [
      {
        "command": "xtech-supabase.refresh",
        "title": "Refresh Supabase Explorer",
        "icon": "$(refresh)"
      },
      {
        "command": "xtech-supabase.createMigration",
        "title": "Create New Migration",
        "icon": "$(add)"
      },
      {
        "command": "xtech-supabase.setToken",
        "title": "Set Supabase Access Token"
      },
      {
        "command": "xtech-supabase.clearToken",
        "title": "Clear Supabase Access Token"
      },
      {
        "command": "xtech-supabase.viewTableSchema",
        "title": "View Table Schema",
        "icon": "$(symbol-namespace)"
      },
      {
        "command": "xtech-supabase.viewTableData",
        "title": "View Table Data",
        "icon": "$(table)"
      },
      {
        "command": "xtech-supabase.viewViewSchema",
        "title": "View View Schema",
        "icon": "$(symbol-namespace)"
      },
      {
        "command": "xtech-supabase.viewViewData",
        "title": "View View Data",
        "icon": "$(table)"
      },
      {
        "command": "xtech-supabase.viewFunctionDetails",
        "title": "View Function Details",
        "icon": "$(symbol-method)"
      },
      {
        "command": "xtech-supabase.viewPolicyDetails",
        "title": "View Policy Details",
        "icon": "$(shield)"
      },
      {
        "command": "xtech-supabase.viewTriggerDetails",
        "title": "View Trigger Details",
        "icon": "$(zap)"
      },
      {
        "command": "xtech-supabase.viewIndexDetails",
        "title": "View Index Details",
        "icon": "$(key)"
      },
      {
        "command": "xtech-supabase.viewRoleDetails",
        "title": "View Role Details",
        "icon": "$(person)"
      },
      {
        "command": "xtech-supabase.viewStorageBucketDetails",
        "title": "View Storage Bucket Details",
        "icon": "$(archive)"
      },
      {
        "command": "xtech-supabase.copySqlTable",
        "title": "Copy SQL",
        "icon": "$(clippy)"
      },
      {
        "command": "xtech-supabase.copySqlView",
        "title": "Copy SQL",
        "icon": "$(clippy)"
      },
      {
        "command": "xtech-supabase.copySqlFunction",
        "title": "Copy SQL",
        "icon": "$(clippy)"
      },
      {
        "command": "xtech-supabase.copySqlPolicy",
        "title": "Copy SQL",
        "icon": "$(clippy)"
      },
      {
        "command": "xtech-supabase.copySqlTrigger",
        "title": "Copy SQL",
        "icon": "$(clippy)"
      },
      {
        "command": "xtech-supabase.copySqlIndex",
        "title": "Copy SQL",
        "icon": "$(clippy)"
      },
      {
        "command": "xtech-supabase.copySqlRole",
        "title": "Copy SQL",
        "icon": "$(clippy)"
      },
      {
        "command": "xtech-supabase.copySqlStorageBucket",
        "title": "Copy SQL",
        "icon": "$(clippy)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "xtech-supabase.refresh",
          "when": "view == xtech-supabase.supabaseExplorer",
          "group": "navigation@1"
        }
      ],
      "view/item/context": [
        {
          "command": "xtech-supabase.viewTableSchema",
          "when": "view == xtech-supabase.supabaseExplorer && viewItem =~ /^table-/",
          "group": "inline@1"
        },
        {
          "command": "xtech-supabase.viewTableData",
          "when": "view == xtech-supabase.supabaseExplorer && viewItem =~ /^table-/",
          "group": "inline@2"
        },
        {
          "command": "xtech-supabase.viewViewSchema",
          "when": "view == xtech-supabase.supabaseExplorer && viewItem =~ /^view-/",
          "group": "inline@1"
        },
        {
          "command": "xtech-supabase.viewViewData",
          "when": "view == xtech-supabase.supabaseExplorer && viewItem =~ /^view-/",
          "group": "inline@2"
        },
        {
          "command": "xtech-supabase.viewFunctionDetails",
          "when": "view == xtech-supabase.supabaseExplorer && viewItem =~ /^function-/",
          "group": "inline@1"
        },
        {
          "command": "xtech-supabase.viewPolicyDetails",
          "when": "view == xtech-supabase.supabaseExplorer && viewItem =~ /^policy-/",
          "group": "inline@1"
        },
        {
          "command": "xtech-supabase.viewTriggerDetails",
          "when": "view == xtech-supabase.supabaseExplorer && viewItem =~ /^trigger-/",
          "group": "inline@1"
        },
        {
          "command": "xtech-supabase.viewIndexDetails",
          "when": "view == xtech-supabase.supabaseExplorer && viewItem =~ /^index-/",
          "group": "inline@1"
        },
        {
          "command": "xtech-supabase.viewRoleDetails",
          "when": "view == xtech-supabase.supabaseExplorer && viewItem =~ /^role-/",
          "group": "inline@1"
        },
        {
          "command": "xtech-supabase.viewStorageBucketDetails",
          "when": "view == xtech-supabase.supabaseExplorer && viewItem =~ /^storageBucket-/",
          "group": "inline@1"
        },
        {
          "command": "xtech-supabase.copySqlTable",
          "when": "view == xtech-supabase.supabaseExplorer && viewItem =~ /^table-/",
          "group": "inline@3"
        },
        {
          "command": "xtech-supabase.copySqlView",
          "when": "view == xtech-supabase.supabaseExplorer && viewItem =~ /^view-/",
          "group": "inline@3"
        },
        {
          "command": "xtech-supabase.copySqlFunction",
          "when": "view == xtech-supabase.supabaseExplorer && viewItem =~ /^function-/",
          "group": "inline@2"
        },
        {
          "command": "xtech-supabase.copySqlPolicy",
          "when": "view == xtech-supabase.supabaseExplorer && viewItem =~ /^policy-/",
          "group": "inline@2"
        },
        {
          "command": "xtech-supabase.copySqlTrigger",
          "when": "view == xtech-supabase.supabaseExplorer && viewItem =~ /^trigger-/",
          "group": "inline@2"
        },
        {
          "command": "xtech-supabase.copySqlIndex",
          "when": "view == xtech-supabase.supabaseExplorer && viewItem =~ /^index-/",
          "group": "inline@2"
        },
        {
          "command": "xtech-supabase.copySqlRole",
          "when": "view == xtech-supabase.supabaseExplorer && viewItem =~ /^role-/",
          "group": "inline@2"
        },
        {
          "command": "xtech-supabase.copySqlStorageBucket",
          "when": "view == xtech-supabase.supabaseExplorer && viewItem =~ /^storageBucket-/",
          "group": "inline@2"
        }
      ]
    },
    "configuration": {
      "title": "XTECH Supabase",
      "properties": {
        "xtech-supabase.projectPath": {
          "type": "string",
          "description": "Override auto-detected Supabase project path"
        },
        "xtech-supabase.authMode": {
          "type": "string",
          "enum": [
            "cli",
            "token"
          ],
          "default": "cli",
          "description": "Auth mode: 'cli' uses Supabase CLI session, 'token' uses stored SecretStorage token"
        },
        "xtech-supabase.refreshInterval": {
          "type": "number",
          "default": 0,
          "description": "Auto-refresh interval in seconds (0 = disabled)"
        },
        "xtech-supabase.localDbUrl": {
          "type": "string",
          "description": "Override local database connection URL"
        },
        "xtech-supabase.linkedProjectRef": {
          "type": "string",
          "description": "Override linked Supabase project reference"
        },
        "xtech-supabase.useDataWrangler": {
          "type": "boolean",
          "default": false,
          "description": "Use Data Wrangler for table/view data display (requires Data Wrangler extension)"
        },
        "xtech-supabase.tempDirectory": {
          "type": "string",
          "description": "Directory for temporary files (defaults to OS temp directory)",
          "default": ".supabase-temp"
        }
      }
    }
  },
  "scripts": {
    "compile": "esbuild src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node",
    "compile:test": "tsc -p ./",
    "typecheck": "tsc -p ./ --noEmit",
    "lint": "eslint src --ext .ts",
    "test": "npm run compile:test && node ./out/test/runTest.js",
    "package": "npm run compile && vsce package",
    "watch": "esbuild src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node --watch"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.0.0",
    "@types/pg": "^8.11.11",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vscode/test-electron": "^2.3.0",
    "@vscode/vsce": "^3.7.1",
    "esbuild": "^0.25.0",
    "eslint": "^8.57.0",
    "glob": "^10.0.0",
    "mocha": "^11.7.5",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "pg": "^8.13.3"
  }
}
